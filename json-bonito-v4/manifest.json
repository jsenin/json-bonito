{
  "manifest_version": 2,
  "name": "Json Bonito",
  "version": "3.0.0",
  "description": "Beautiful JSON formatter — opens in a full tab for comfortable editing.",
  "icons": {
    "48":  "icon48.png",
    "96":  "icon96.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_icon": {
      "48":  "icon48.png",
      "96":  "icon96.png",
      "128": "icon128.png"
    },
    "default_title": "Json Bonito"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "permissions": [
    "tabs",
    "storage"
  ]
}
